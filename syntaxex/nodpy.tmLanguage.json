{
  "name": "NodPy",
  "scopeName": "source.nodpy",
  "fileTypes": ["nodpy"],
  "patterns": [
    { "include": "#nodpy-py-import" },
    { "include": "#nodpy-python-block" },
    { "include": "#nodpy-dollar-bridge" },
    { "include": "#nodpy-py-tag" },
    { "include": "#nodpy-result-keyword" },
    { "include": "source.js" }
  ],
  "repository": {

    "nodpy-py-import": {
      "comment": "import py 'module' as alias",
      "match": "^(\\s*)(import)\\s+(py)\\s+(['\"][^'\"]+['\"])(?:\\s+(as)\\s+([a-zA-Z_$][\\w$]*))?",
      "captures": {
        "2": { "name": "keyword.control.import.js" },
        "3": { "name": "keyword.other.nodpy.py storage.type.nodpy" },
        "4": { "name": "string.quoted.single.js" },
        "5": { "name": "keyword.control.as.js" },
        "6": { "name": "variable.other.constant.js" }
      }
    },

    "nodpy-python-block": {
      "comment": "python { ... } block — closes on a line whose first non-space char is }",
      "begin": "(?:^|(?<=[;,({\\[]))(\\s*)(python)\\s*(\\{)",
      "beginCaptures": {
        "2": { "name": "keyword.control.nodpy storage.type.nodpy" },
        "3": { "name": "punctuation.section.block.begin.nodpy" }
      },
      "end": "^(\\s*)(\\})",
      "endCaptures": {
        "2": { "name": "punctuation.section.block.end.nodpy" }
      },
      "name": "meta.embedded.block.python.nodpy",
      "contentName": "source.python",
      "patterns": [
        { "include": "source.python" }
      ]
    },

    "nodpy-dollar-bridge": {
      "comment": "$varName — bridge JS variable to Python",
      "match": "^(\\s*)(\\$)([a-zA-Z_$][\\w$]*)\\s*;?\\s*$",
      "captures": {
        "2": { "name": "keyword.operator.nodpy keyword.operator.assignment.js" },
        "3": { "name": "variable.other.readwrite.js" }
      }
    },

    "nodpy-py-tag": {
      "comment": "py`expression` — inline Python eval",
      "begin": "(?<![\\w$])(py)(`)",
      "beginCaptures": {
        "1": { "name": "keyword.other.nodpy storage.type.nodpy" },
        "2": { "name": "string.template.js punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "string.template.js punctuation.definition.string.template.end.js" }
      },
      "name": "meta.embedded.expression.python.nodpy",
      "contentName": "source.python",
      "patterns": [
        { "include": "source.python" }
      ]
    },

    "nodpy-result-keyword": {
      "comment": "__nodpy_result__ special variable",
      "match": "\\b(__nodpy_result__)\\b",
      "captures": {
        "1": { "name": "variable.language.nodpy support.variable.nodpy" }
      }
    }

  }
}
